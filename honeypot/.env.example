# Honeypot Configuration
# ========================
# Most settings can be configured via the web GUI at /admin/settings
# These environment variables are for initial setup or Docker deployments

# Admin Dashboard (REQUIRED - change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-immediately

# JWT Secret for admin sessions (auto-generated by setup.sh)
JWT_SECRET=your-256-bit-secret-here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./honeypot.db

# ============================================
# OPTIONAL - Can also be set via /admin/settings GUI
# ============================================

# Groq AI Analysis (free at console.groq.com)
GROQ_API_KEY=

# GeoIP (free at maxmind.com)
MAXMIND_LICENSE_KEY=
GEOIP_DB_PATH=./GeoLite2-City.mmdb

# Webhooks (Slack, Discord, SIEM)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
WEBHOOK_URL=

# Multi-port (comma-separated)
ADDITIONAL_PORTS=

# Logging Level
LOG_LEVEL=INFO
